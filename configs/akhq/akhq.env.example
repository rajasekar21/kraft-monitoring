AKHQ_JWT_SECRET=replace-with-strong-random-secret-at-least-256-bits

LDAP_URI=ldaps://ldap-01.example.com:636
LDAP_MANAGER_DN=cn=akhq-reader,ou=service-accounts,dc=example,dc=com
LDAP_MANAGER_PASSWORD=replace-with-existing-ldap-bind-password
LDAP_USER_BASE=ou=users,dc=example,dc=com
LDAP_USER_FILTER=uid={0}
LDAP_GROUP_BASE=ou=groups,dc=example,dc=com
LDAP_GROUP_FILTER=member={0}

KAFKA_BOOTSTRAP_SERVERS=kafka-01.example.com:9093,kafka-02.example.com:9093,kafka-03.example.com:9093
KAFKA_AKHQ_USERNAME=akhq_prod_operator
KAFKA_AKHQ_PASSWORD=replace-with-kafka-sasl-password
KAFKA_TRUSTSTORE_LOCATION=/etc/akhq/certs/kafka.truststore.jks
KAFKA_TRUSTSTORE_PASSWORD=replace-with-truststore-password
